(function () {
  // ============================================
  // CHAT FLOTANTE INVISIBLE + GEMINI
  // Especificaciones:
  // - Totalmente invisible cuando no pasas el cursor encima.
  // - Al pasar el cursor encima, aparece con opacidad.
  // - Botón ChatGPT: copia la pregunta y abre ChatGPT.
  // - Botón Google: busca la pregunta en Google y cierra el chat.
  // - Botón Gemini: envía la pregunta al Worker y muestra la respuesta.
  // - Por defecto, Gemini cierra el chat después de 10 segundos.
  // - Botón "Desactivar 10s": desactiva/activa el cierre automático de Gemini.
  // - Botón "Borrar mensajes": limpia pregunta y respuesta.
  // - Atajo Ctrl + K: muestra/oculta el chat.
  // ============================================

  var oldBox = document.getElementById('studyChatBox');
  if (oldBox) oldBox.remove();

  var oldStyle = document.getElementById('studyChatStyle');
  if (oldStyle) oldStyle.remove();

  var autoCloseTimer = null;
  var autoCloseStorageKey = 'studyGeminiAutoCloseDisabled';

  var css = document.createElement('style');
  css.id = 'studyChatStyle';

  css.innerHTML = `
#studyChatBox,#studyChatBox *{
  box-sizing:border-box!important;
  font-family:Arial!important;
}

#studyChatBox{
  position:fixed!important;
  right:18px!important;
  bottom:78px!important;
  width:350px!important;
  height:auto!important;
  background:transparent!important;
  border:1px solid transparent!important;
  border-radius:10px!important;
  box-shadow:none!important;
  z-index:999999!important;
  overflow:visible!important;
  opacity:0!important;
  transition:opacity .18s,background .18s!important;
}

#studyChatBox:hover{
  opacity:.68!important;
  background:transparent!important;
  box-shadow:none!important;
}

#studyChatHeader{
  height:24px!important;
  background:transparent!important;
  border-bottom:1px solid rgba(203,213,225,.06)!important;
  display:flex!important;
  justify-content:flex-end!important;
  align-items:center!important;
  padding:0 5px!important;
  gap:5px!important;
}

#studyGeminiTimerToggle,
#studyClearMessages{
  border:1px solid rgba(203,213,225,.10)!important;
  background:transparent!important;
  color:rgba(17,24,39,.28)!important;
  border-radius:6px!important;
  height:18px!important;
  padding:0 6px!important;
  cursor:pointer!important;
  font-size:9px!important;
  font-weight:600!important;
  white-space:nowrap!important;
}

#studyChatClose{
  border:1px solid rgba(203,213,225,.10)!important;
  background:transparent!important;
  color:rgba(17,24,39,.25)!important;
  border-radius:6px!important;
  width:22px!important;
  height:18px!important;
  cursor:pointer!important;
  font-size:13px!important;
}

#studyChatBox:hover #studyGeminiTimerToggle,
#studyChatBox:hover #studyClearMessages,
#studyChatBox:hover #studyChatClose{
  background:rgba(255,255,255,.10)!important;
  color:rgba(17,24,39,.65)!important;
}

#studyGeminiTimerToggle.off{
  color:rgba(150,20,20,.70)!important;
  border-color:rgba(150,20,20,.25)!important;
}

#studyGeminiTimerToggle.on{
  color:rgba(20,90,40,.70)!important;
  border-color:rgba(20,90,40,.25)!important;
}

#studyClearMessages{
  color:rgba(80,80,80,.60)!important;
}

#studyChatBody{
  padding:7px!important;
  background:transparent!important;
}

#studyQuestion{
  width:100%!important;
  height:58px!important;
  resize:vertical!important;
  border:1px solid rgba(203,213,225,.10)!important;
  border-radius:7px!important;
  padding:6px!important;
  font-size:11px!important;
  outline:none!important;
  background:transparent!important;
  color:rgba(17,24,39,.35)!important;
}

#studyChatBox:hover #studyQuestion,
#studyQuestion:focus{
  background:rgba(255,255,255,.16)!important;
  color:rgba(17,24,39,.82)!important;
  border-color:rgba(203,213,225,.30)!important;
}

#studyQuestion::placeholder{
  color:rgba(17,24,39,.22)!important;
}

#studyAnswer{
  display:none!important;
  width:100%!important;
  min-height:38px!important;
  max-height:190px!important;
  overflow:auto!important;
  margin-top:7px!important;
  margin-bottom:7px!important;
  border:1px solid rgba(203,213,225,.12)!important;
  border-radius:7px!important;
  padding:7px!important;
  background:rgba(255,255,255,.08)!important;
  color:rgba(17,24,39,.55)!important;
  font-size:11px!important;
  line-height:1.35!important;
  white-space:pre-wrap!important;
  word-break:break-word!important;
}

#studyChatBox:hover #studyAnswer{
  background:rgba(255,255,255,.18)!important;
  color:rgba(17,24,39,.88)!important;
}

#studyChatButtons{
  display:flex!important;
  gap:5px!important;
  margin-top:6px!important;
}

#studyChatSend,
#studyGoogleBtn,
#studyGeminiBtn{
  flex:1!important;
  border:1px solid rgba(203,213,225,.10)!important;
  border-radius:7px!important;
  height:24px!important;
  background:transparent!important;
  color:rgba(17,24,39,.28)!important;
  font-size:10px!important;
  font-weight:600!important;
  cursor:pointer!important;
}

#studyChatBox:hover #studyChatSend,
#studyChatBox:hover #studyGoogleBtn,
#studyChatBox:hover #studyGeminiBtn{
  background:rgba(255,255,255,.14)!important;
  color:rgba(17,24,39,.70)!important;
}

#studyGeminiBtn:disabled{
  opacity:.55!important;
  cursor:wait!important;
}
`;

  document.head.appendChild(css);

  var box = document.createElement('div');
  box.id = 'studyChatBox';

  box.innerHTML = `
<div id="studyChatHeader">
  <button id="studyGeminiTimerToggle" type="button">Desactivar 10s</button>
  <button id="studyClearMessages" type="button">Borrar mensajes</button>
  <button id="studyChatClose" type="button">−</button>
</div>

<div id="studyChatBody">
  <textarea id="studyQuestion" placeholder="Escribe tu pregunta..."></textarea>

  <div id="studyAnswer"></div>

  <div id="studyChatButtons">
    <button id="studyChatSend" type="button">ChatGPT</button>
    <button id="studyGoogleBtn" type="button">Google</button>
    <button id="studyGeminiBtn" type="button">Gemini</button>
  </div>
</div>
`;

  document.body.appendChild(box);

  function isAutoCloseDisabled() {
    return localStorage.getItem(autoCloseStorageKey) === '1';
  }

  function updateTimerButton() {
    var btn = document.getElementById('studyGeminiTimerToggle');
    if (!btn) return;

    if (isAutoCloseDisabled()) {
      btn.textContent = 'Activar 10s';
      btn.classList.remove('on');
      btn.classList.add('off');
      btn.title = 'El cuadro ya no se cerrará solo después de preguntar a Gemini';
    } else {
      btn.textContent = 'Desactivar 10s';
      btn.classList.remove('off');
      btn.classList.add('on');
      btn.title = 'El cuadro se cerrará 10 segundos después de responder Gemini';
    }
  }

  function closeBox() {
    var q = document.getElementById('studyQuestion');
    if (q) q.value = '';

    clearAnswer();
    box.style.display = 'none';
  }

  function resetChat() {
    if (autoCloseTimer) {
      clearTimeout(autoCloseTimer);
      autoCloseTimer = null;
    }

    var q = document.getElementById('studyQuestion');
    if (q) {
      q.value = '';
      q.focus();
    }

    clearAnswer();

    var geminiBtn = document.getElementById('studyGeminiBtn');
    if (geminiBtn) {
      geminiBtn.disabled = false;
      geminiBtn.textContent = 'Gemini';
    }
  }

  function startAutoClose() {
    if (autoCloseTimer) clearTimeout(autoCloseTimer);

    if (isAutoCloseDisabled()) {
      return;
    }

    autoCloseTimer = setTimeout(function () {
      closeBox();
    }, 10000);
  }

  function ensureAnswerBox() {
    var ans = document.getElementById('studyAnswer');

    if (!ans) {
      ans = document.createElement('div');
      ans.id = 'studyAnswer';

      var body = document.getElementById('studyChatBody');
      var buttons = document.getElementById('studyChatButtons');

      if (body && buttons) {
        body.insertBefore(ans, buttons);
      } else if (body) {
        body.appendChild(ans);
      }
    }

    return ans;
  }

  function setAnswer(text) {
    var ans = ensureAnswerBox();
    if (!ans) return;

    ans.textContent = text || '';
    ans.style.setProperty('display', 'block', 'important');
    ans.style.setProperty('visibility', 'visible', 'important');
    ans.style.setProperty('opacity', '1', 'important');
    ans.style.setProperty('height', 'auto', 'important');
    ans.style.setProperty('min-height', '38px', 'important');
    ans.style.setProperty('max-height', '190px', 'important');
    ans.style.setProperty('overflow', 'auto', 'important');
    ans.scrollTop = 0;
  }

  function clearAnswer() {
    var ans = ensureAnswerBox();
    if (!ans) return;

    ans.textContent = '';
    ans.style.setProperty('display', 'none', 'important');
  }

  document.getElementById('studyGeminiTimerToggle').onclick = function () {
    if (isAutoCloseDisabled()) {
      localStorage.removeItem(autoCloseStorageKey);
    } else {
      localStorage.setItem(autoCloseStorageKey, '1');

      if (autoCloseTimer) {
        clearTimeout(autoCloseTimer);
        autoCloseTimer = null;
      }
    }

    updateTimerButton();
  };

  document.getElementById('studyClearMessages').onclick = function () {
    resetChat();
  };

  document.getElementById('studyChatClose').onclick = function () {
    if (autoCloseTimer) clearTimeout(autoCloseTimer);
    closeBox();
  };

  document.getElementById('studyChatSend').onclick = function () {
    var q = document.getElementById('studyQuestion').value.trim();
    if (!q) return;

    var t = document.createElement('textarea');
    t.value = q;
    t.style.position = 'fixed';
    t.style.left = '-9999px';

    document.body.appendChild(t);
    t.focus();
    t.select();

    try {
      document.execCommand('copy');
    } catch (e) {}

    document.body.removeChild(t);

    window.open(
      'https://chatgpt.com/',
      '_blank',
      'width=560,height=740,left=80,top=60,resizable=yes,scrollbars=yes,noopener,noreferrer'
    );

    closeBox();
  };

  document.getElementById('studyGoogleBtn').onclick = function () {
    var q = document.getElementById('studyQuestion').value.trim();
    if (!q) return;

    window.open(
      'https://www.google.com/search?q=' + encodeURIComponent(q),
      '_blank',
      'width=780,height=740,left=120,top=60,resizable=yes,scrollbars=yes,noopener,noreferrer'
    );

    closeBox();
  };

  document.getElementById('studyGeminiBtn').onclick = async function () {
    var q = document.getElementById('studyQuestion').value.trim();

    if (!q) {
      setAnswer('Escribe una pregunta primero.');
      startAutoClose();
      return;
    }

    var workerUrl = window.__DANLO_WORKER_URL || 'https://danlo2.danlogrimo.workers.dev/';
    var tokenKey = window.__DANLO_TOKEN_KEY || 'danlo_token_worker_v9';
    var token = sessionStorage.getItem(tokenKey);

    if (!token) {
      setAnswer('Primero ejecuta el marcador con la clave correcta.');
      startAutoClose();
      return;
    }

    var btn = document.getElementById('studyGeminiBtn');
    btn.disabled = true;
    btn.textContent = '...';

    setAnswer('Pensando...');

    try {
      var r = await fetch(workerUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          action: 'ask',
          token: token,
          message: q
        })
      });

      var j = await r.json();

      if (!j.ok) {
        setAnswer(j.error || 'No se pudo obtener respuesta.');
        startAutoClose();
        return;
      }

      setAnswer(j.answer || 'Sin respuesta.');
      startAutoClose();

    } catch (e) {
      setAnswer('No se pudo conectar con Gemini: ' + e.message);
      startAutoClose();

    } finally {
      btn.disabled = false;
      btn.textContent = 'Gemini';
    }
  };

  document.addEventListener(
    'keydown',
    function (e) {
      if (e.ctrlKey && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        e.stopPropagation();

        var b = document.getElementById('studyChatBox');
        if (!b) return;

        if (b.style.display === 'none') {
          b.style.display = 'block';

          setTimeout(function () {
            var i = document.getElementById('studyQuestion');
            if (i) i.focus();
          }, 80);

        } else {
          if (autoCloseTimer) clearTimeout(autoCloseTimer);
          closeBox();
        }
      }
    },
    true
  );

  updateTimerButton();

  setTimeout(function () {
    var input = document.getElementById('studyQuestion');
    if (input) input.focus();
  }, 80);
})();
