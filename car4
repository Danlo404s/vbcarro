(function () {
  if (document.getElementById('studyChatBox')) {
    var b = document.getElementById('studyChatBox');
    b.style.display = b.style.display === 'none' ? 'block' : 'none';
    return;
  }

  var css = document.createElement('style');
  css.innerHTML = `
#studyChatBox,#studyChatBox *{box-sizing:border-box!important;font-family:Arial!important}
#studyChatBox{position:fixed!important;right:18px!important;bottom:78px!important;width:285px!important;background:rgba(255,255,255,.08)!important;border:1px solid rgba(203,213,225,.16)!important;border-radius:10px!important;box-shadow:none!important;z-index:999999!important;overflow:hidden!important;opacity:.32!important;transition:opacity .18s,background .18s!important}
#studyChatBox:hover,#studyChatBox:focus-within{opacity:.65!important;background:rgba(255,255,255,.28)!important;box-shadow:none!important}
#studyChatHeader{height:22px!important;background:transparent!important;border-bottom:1px solid rgba(203,213,225,.12)!important;display:flex!important;justify-content:flex-end!important;align-items:center!important;padding:0 5px!important}
#studyChatClose{border:1px solid rgba(203,213,225,.18)!important;background:rgba(255,255,255,.08)!important;color:rgba(17,24,39,.35)!important;border-radius:6px!important;width:22px!important;height:18px!important;cursor:pointer!important;font-size:13px!important}
#studyChatBox:hover #studyChatClose{background:rgba(255,255,255,.18)!important;color:rgba(17,24,39,.55)!important}
#studyChatBody{padding:7px!important;background:transparent!important}
#studyQuestion{width:100%!important;height:54px!important;resize:vertical!important;border:1px solid rgba(203,213,225,.18)!important;border-radius:7px!important;padding:6px!important;font-size:11px!important;outline:none!important;background:rgba(255,255,255,.06)!important;color:rgba(17,24,39,.45)!important}
#studyChatBox:hover #studyQuestion,#studyQuestion:focus{background:rgba(255,255,255,.28)!important;color:rgba(17,24,39,.75)!important;border-color:rgba(203,213,225,.32)!important}
#studyQuestion::placeholder{color:rgba(17,24,39,.25)!important}
#studyChatButtons{display:flex!important;gap:5px!important;margin-top:6px!important}
#studyChatSend,#studyGoogleBtn,#studyGeminiBtn{flex:1!important;border:1px solid rgba(203,213,225,.16)!important;border-radius:7px!important;height:24px!important;background:rgba(255,255,255,.05)!important;color:rgba(17,24,39,.32)!important;font-size:10px!important;font-weight:600!important;cursor:pointer!important}
#studyChatBox:hover #studyChatSend,#studyChatBox:hover #studyGoogleBtn,#studyChatBox:hover #studyGeminiBtn{background:rgba(255,255,255,.22)!important;color:rgba(17,24,39,.65)!important}
#studyGeminiBtn:disabled{opacity:.55!important;cursor:wait!important}
#studyAnswer{display:none!important;margin-top:7px!important;max-height:170px!important;overflow:auto!important;border:1px solid rgba(203,213,225,.22)!important;border-radius:7px!important;padding:7px!important;background:rgba(255,255,255,.14)!important;color:rgba(17,24,39,.72)!important;font-size:11px!important;line-height:1.35!important;white-space:pre-wrap!important}
#studyChatBox:hover #studyAnswer{background:rgba(255,255,255,.32)!important;color:rgba(17,24,39,.85)!important}
`;

  document.head.appendChild(css);

  var box = document.createElement('div');
  box.id = 'studyChatBox';
  box.innerHTML = `
<div id="studyChatHeader">
  <button id="studyChatClose" type="button">−</button>
</div>
<div id="studyChatBody">
  <textarea id="studyQuestion" placeholder="Escribe..."></textarea>
  <div id="studyChatButtons">
    <button id="studyChatSend" type="button">ChatGPT</button>
    <button id="studyGoogleBtn" type="button">Google</button>
    <button id="studyGeminiBtn" type="button">Gemini</button>
  </div>
  <div id="studyAnswer"></div>
</div>
`;

  document.body.appendChild(box);

  function setAnswer(text) {
    var ans = document.getElementById('studyAnswer');
    if (!ans) return;
    ans.textContent = text;
    ans.style.setProperty('display', 'block', 'important');
  }

  function clearAnswer() {
    var ans = document.getElementById('studyAnswer');
    if (!ans) return;
    ans.textContent = '';
    ans.style.setProperty('display', 'none', 'important');
  }

  document.getElementById('studyChatClose').onclick = function () {
    document.getElementById('studyQuestion').value = '';
    clearAnswer();
    box.style.display = 'none';
  };

  document.getElementById('studyChatSend').onclick = function () {
    var q = document.getElementById('studyQuestion').value.trim();
    if (!q) return;

    var t = document.createElement('textarea');
    t.value = q;
    t.style.position = 'fixed';
    t.style.left = '-9999px';
    document.body.appendChild(t);
    t.focus();
    t.select();

    try {
      document.execCommand('copy');
    } catch (e) {}

    document.body.removeChild(t);

    window.open(
      'https://chatgpt.com/',
      '_blank',
      'width=560,height=740,left=80,top=60,resizable=yes,scrollbars=yes,noopener,noreferrer'
    );

    document.getElementById('studyQuestion').value = '';
    clearAnswer();
    box.style.display = 'none';
  };

  document.getElementById('studyGoogleBtn').onclick = function () {
    var q = document.getElementById('studyQuestion').value.trim();
    if (!q) return;

    window.open(
      'https://www.google.com/search?q=' + encodeURIComponent(q),
      '_blank',
      'width=780,height=740,left=120,top=60,resizable=yes,scrollbars=yes,noopener,noreferrer'
    );

    document.getElementById('studyQuestion').value = '';
    clearAnswer();
    box.style.display = 'none';
  };

  document.getElementById('studyGeminiBtn').onclick = async function () {
    var q = document.getElementById('studyQuestion').value.trim();
    if (!q) return;

    var workerUrl = window.__DANLO_WORKER_URL || 'https://danlo2.danlogrimo.workers.dev/';
    var tokenKey = window.__DANLO_TOKEN_KEY || 'danlo_token_worker_v9';
    var token = sessionStorage.getItem(tokenKey);

    if (!token) {
      setAnswer('Primero ejecuta el marcador con la clave correcta.');
      return;
    }

    var btn = document.getElementById('studyGeminiBtn');
    btn.disabled = true;
    btn.textContent = '...';

    setAnswer('Pensando...');

    try {
      var r = await fetch(workerUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          action: 'ask',
          token: token,
          message: q
        })
      });

      var j = await r.json();

      if (!j.ok) {
        setAnswer(j.error || 'No se pudo obtener respuesta.');
        return;
      }

      setAnswer(j.answer || 'Sin respuesta.');
    } catch (e) {
      setAnswer('No se pudo conectar con Gemini: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Gemini';
    }
  };

  document.addEventListener(
    'keydown',
    function (e) {
      if (e.ctrlKey && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        e.stopPropagation();

        var b = document.getElementById('studyChatBox');
        if (!b) return;

        if (b.style.display === 'none') {
          b.style.display = 'block';
          setTimeout(function () {
            var i = document.getElementById('studyQuestion');
            if (i) i.focus();
          }, 80);
        } else {
          var i = document.getElementById('studyQuestion');
          if (i) i.value = '';
          clearAnswer();
          b.style.display = 'none';
        }
      }
    },
    true
  );
})();
